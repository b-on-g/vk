$bog_vk_app $mol_page
	plugins /
		<= Theme $bog_theme_auto
		<= Popup_fix $bog_popup_plugin
		<= Tooltip $bog_tooltip_plugin
	title \Bog Music
	Title <= Brand $mol_image
		uri \bog/vk/app/favicon.svg
		title <= title
	tools /
		<= Nickname_label $mol_view
			sub / <= nickname_label \
		<= Wave_toggle $mol_check_icon
			hint \Моя волна
			Icon <= Wave_icon $mol_icon_chart_timeline_variant
			checked? <=> wave_mode? false
		<= Account_toggle $mol_check_icon
			hint \Аккаунт
			Icon <= Account_icon $mol_icon_account_circle
			checked? <=> account_open? false
		<= Upload $mol_button_open
			hint \Загрузить с устройства
			accept \audio/*
			files? <=> upload_files? /File
		<= Theme_btn $bog_theme_toggle
			theme_auto <= Theme
	body_scroll_top? <=> scroll? 0
	body /
		<= Account $bog_vk_account
		<= Tabs $mol_switch
			value? <=> page? \my
			options <= tab_options *
				my \Моя музыка
				search \Поиск
				archive \Архив
		<= Search_bar $mol_string
			hint \Поиск музыки...
			value? <=> search_query? \
		<= Tracks $bog_vk_tracks
			audios <= visible_audios /
			current_audio <= current_audio null
			play_audio? <=> on_play_audio? null
			archive_mode <= archive_mode false
			reorder_to? <=> reorder_to? null
			archive_audio? <=> archive_audio? null
			restore_audio? <=> restore_audio? null
			delete_audio? <=> delete_audio? null
	foot /
		<= Player $bog_vk_player
			queue <= visible_audios /
			current_audio? <=> current_audio? null
			pick_next? <=> player_pick_next? null

