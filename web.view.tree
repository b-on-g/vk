$giper_baza_app_stat_page $mol_page
	home $giper_baza_app_home
		link => home_link
	title \📊 Server Statistics
	head /
		<= Main $mol_view sub / 
			<= Land $giper_baza_link_chip
				link <= home_link
				arg *
					section \glob
					^
			<= Uptime $mol_chip title <= uptime \🔴 00:00
		<= Tools
	body_content /
		<= Charts $mol_gallery items /
			<= Cpu $mol_chart
				graphs /
					<= Cpu_user $mol_plot_line
						title \CPU User (%)
						series_y <= cpu_user /
					<= Cpu_system $mol_plot_line
						title \CPU System (%)
						series_y <= cpu_system /
					<= Cpu_ruler_sec $mol_plot_ruler_vert
					<= Cpu_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Cpu_user
							<= Cpu_system
			<= Mem $mol_chart
				graphs /
					<= Mem_free $mol_plot_line
						title \Mem Free (%)
						series_y <= mem_free /
					<= Mem_used $mol_plot_line
						title \Mem Used (%)
						series_y <= mem_used /
					<= Mem_ruler $mol_plot_ruler_vert
					<= Mem_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Mem_used
							<= Mem_free
			<= Fs_usage $mol_chart
				graphs /
					<= Fs_free $mol_plot_line
						title \FS Free (%)
						series_y <= fs_free /
					<= Fs_usage_ruler $mol_plot_ruler_vert
					<= Fs_usage_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Fs_free
			<= Fs_acting $mol_chart
				graphs /
					<= Fs_reads $mol_plot_line
						title \FS Reads / sec
						series_y <= fs_reads /
					<= Fs_writes $mol_plot_line
						title \FS Writes / sec
						series_y <= fs_writes /
					<= Fs_acting_ruler $mol_plot_ruler_vert
					<= Fs_acting_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Fs_reads
							<= Fs_writes
			<= Ports $mol_chart
				graphs /
					<= Port_slaves $mol_plot_line
						title \Slave Ports
						series_y <= port_slaves /
					<= Port_masters $mol_plot_line
						title \Master Ports
						series_y <= port_masters /
					<= Port_ruler_pct $mol_plot_ruler_vert
					<= Port_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Port_slaves
							<= Port_masters
			<= Land_count $mol_chart
				graphs /
					<= Land_active $mol_plot_line
						title \Active Lands
						series_y <= land_active /
					<= Land_count_ruler $mol_plot_ruler_vert
					<= Land_count_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Land_active
			<= Error_count $mol_chart
				graphs /
					<= Errors $mol_plot_line
						title \Errors
						series_y <= errors /
					<= Error_count_ruler $mol_plot_ruler_vert
					<= Error_count_mark $mol_plot_mark_cross
						labels <= times /
						graphs /
							<= Errors

$giper_baza_auth_slot $mol_page
	title \🎰 Beautiful Keys Mining
	glob $giper_baza_glob
	prefix? \
	found*? /string
	body /
		<= Input $mol_bar sub /
			<= Prefix $mol_string
				hint \Prefix
				value? <=> prefix? \
				submit? <=> run? null
			<= Running $mol_check_icon
				Icon <= Run_icon $mol_icon_play
				checked? <=> running? false
				enabled <= run_enabled false
				label /
					<= grabbing
		<= Keys $mol_list
			rows <= keys /
				<= Key*0 $mol_button_copy
					title <= link* \
					text <= key* \

$giper_baza_app $mol_book2_catalog
	menu_title \Giper Baza
	param \section
	menu_foot /
		<= Source $mol_link_source
			uri \https://github.com/giper-dev/baza
		<= Status $giper_baza_status
	spreads *
		info <= Info $mol_frame
			title \💨 Giper Encyclopedy
			uri \https://page.hyoo.ru/#!=sy2u0y_9rb8zj
		glob <= Glob $giper_baza_glob_book
			addon_tools /
				<= Spread_close
		stat <= Stat $giper_baza_app_stat_page
			tools /
				<= Spread_close
		slot <= Slot $giper_baza_auth_slot
			tools /
				<= Spread_close
	placeholders /

$bog_vk_app $mol_page
	plugins /
		<= Theme $mol_theme_auto
		<= Popup_fix $bog_vk_popup_fix
	title \Bog Music
	tools /
		<= Token_popup $mol_pop
			showed? <=> token_popup_open? false
			align \bottom_left
			Anchor <= Token_toggle $mol_check_icon
				hint \Токен
				Icon <= Token_icon $mol_icon_key_variant
				checked? <=> token_popup_open? false
			bubble_content /
				<= Token_panel $mol_list
					rows /
						<= Token_input $mol_string
							hint \Вставь токен или cURL
							value? <=> token? \
						<= Token_clear $mol_button_minor
							title \Удалить токен
							click? <=> clear_token? null
		<= Settings_popup $mol_pop
			showed? <=> settings_popup_open? false
			align \bottom_left
			Anchor <= Settings_toggle $mol_check_icon
				hint \Настройки прокси
				Icon <= Settings_icon $mol_icon_cog
				checked? <=> settings_popup_open? false
			bubble_content /
				<= Settings_panel $mol_list
					rows /
						<= Proxy_hint $mol_paragraph
							title \URL прокси для обхода блокировок
						<= Proxy_input $mol_string
							hint \https://my-proxy.example.com
							value? <=> proxy_url? \
						<= Proxy_reset $mol_button_minor
							title \Сбросить на дефолтный
							click? <=> reset_proxy? null
		<= Account_popup $mol_pop
			showed? <=> account_popup_open? false
			align \bottom_left
			Anchor <= Account_toggle $mol_check_icon
				hint \Аккаунт
				Icon <= Account_icon $mol_icon_account_circle
				checked? <=> account_popup_open? false
			bubble_content /
				<= Account_panel $mol_list
					rows /
						<= Account_id $mol_view
							sub /
								\ЛК:
								<= Account_id_text $mol_view sub / <= account_lord_short \
						<= Account_warning $mol_paragraph
							title \Ссылка ниже — СЕКРЕТ. Не делись ей публично.
						<= Account_copy $mol_button_minor
							title \Скопировать ссылку для переноса
							click? <=> copy_account_link? null
						<= Account_copy_status $mol_view sub / <= copy_status \
						<= Account_import_hint $mol_paragraph
							title \Перенести с другого устройства — вставь ссылку:
						<= Account_import_input $mol_string
							hint \https://.../vk/#account=...
							value? <=> import_link? \
						<= Account_import_apply $mol_button_minor
							title \Применить
							click? <=> apply_account_link? null
						<= Account_import_status $mol_view sub / <= import_status \
		<= Help_toggle $mol_check_icon
			hint \Подсказка
			Icon <= Help_icon $mol_icon_help_circle_outline
			checked? <=> show_hint? true
		<= Upload $mol_button_open
			hint \Загрузить с устройства
			accept \audio/*
			files? <=> upload_files? /File
		<= Download_all $mol_button_minor
			click? <=> download_all? null
			sub /
				<= Download_all_icon $mol_icon_download
		<= Version $bog_version
			version \0.2.2
		<= Sync_status $giper_baza_status
		<= Lighter $mol_lights_toggle
	body_scroll_top? <=> scroll? 0
	body /
		<= Auth_block $mol_view
			sub /
				<= Auth_link $mol_link
					uri \https://vk.com/audios374092255
					target \_blank
					sub / \Открыть аудио
				<= Auth_hint $mol_paragraph
					title <= token_hint \
		<= Tabs $mol_switch
			value? <=> page? \my
			options <= tab_options *
				my \Моя музыка
				search \Поиск
				archive \Архив
		<= Search_bar $mol_string
			hint \Поиск музыки...
			value? <=> search_query? \
		<= Tracks $bog_vk_tracks
			audios <= visible_audios /
			current_audio <= current_audio null
			play_audio? <=> on_play_audio? null
			archive_mode <= archive_mode false
			reorder_up? <=> reorder_up? null
			reorder_down? <=> reorder_down? null
			archive_audio? <=> archive_audio? null
			restore_audio? <=> restore_audio? null
			delete_audio? <=> delete_audio? null
	foot /
		<= Player $bog_vk_player
			queue <= visible_audios /
			current_audio? <=> current_audio? null

$mol_float $mol_view
