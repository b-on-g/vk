{
	"manifest_version": 3,
	"name": "Bog VK Music",
	"short_name": "Bog VK",
	"description": "VK music player with offline cache and Giper Baza sync",
	"version": "1.2.2.1",
	"action": {
		"default_title": "Bog VK Music",
		"default_icon": "bog/vk/app/favicon.svg"
	},
	"background": {
		"service_worker": "bog/vk/ext/background.js"
	},
	"permissions": ["storage", "cookies", "offscreen", "tabs"],
	"host_permissions": [
		"https://api.vk.com/*",
		"https://*.vk.com/*",
		"https://vk.com/*",
		"https://*.vk.ru/*",
		"https://vk.ru/*",
		"https://*.userapi.com/*",
		"https://baza.giper.dev/*",
		"wss://baza.giper.dev/*"
	],
	"icons": [
		{
			"src": "bog/vk/app/favicon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "bog/vk/app/favicon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "maskable"
		}
	],
	"content_scripts": [
		{
			"matches": [
				"*://*.vk.com/*",
				"*://vk.com/*",
				"*://*.vk.ru/*",
				"*://vk.ru/*"
			],
			"js": ["bog/vk/ext/content.js"],
			"run_at": "document_start",
			"all_frames": false
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["bog/vk/ext/inject.js"],
			"matches": [
				"*://*.vk.com/*",
				"*://vk.com/*",
				"*://*.vk.ru/*",
				"*://vk.ru/*"
			]
		}
	]
}
