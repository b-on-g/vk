{
	"manifest_version": 3,
	"name": "Bog VK Music",
	"short_name": "Bog VK",
	"description": "VK music player with offline cache, Giper Baza sync, and direct VK API access",
	"version": "0.3.0",
	"action": {
		"default_popup": "index.html",
		"default_title": "Bog VK Music",
		"default_icon": "bog/vk/app/favicon.svg"
	},
	"permissions": [
		"storage",
		"cookies"
	],
	"host_permissions": [
		"https://api.vk.com/*",
		"https://*.vk.com/*",
		"https://*.userapi.com/*",
		"https://baza.giper.dev/*",
		"wss://baza.giper.dev/*"
	],
	"icons": {
		"16": "bog/vk/app/favicon.svg",
		"48": "bog/vk/app/favicon.svg",
		"128": "bog/vk/app/favicon.svg"
	}
}
